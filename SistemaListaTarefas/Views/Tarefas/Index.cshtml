@model IEnumerable<SistemaListaTarefas.Models.Tarefa>

@{
    ViewData["Title"] = "Lista de Tarefas";
}

<h1 class="display-4">@ViewData["Title"]</h1>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Custo (R$)</th>
            <th>Data Limite</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            @* Regra: Custo >= 1000 fica com fundo amarelo [cite: 22] *@
            <tr style="@(item.Custo >= 1000 ? "background-color: yellow;" : "")">
                <td>@item.Nome</td>
                @* Formato brasileiro: R$ [cite: 12, 16] *@
                <td>@item.Custo.ToString("C2", new System.Globalization.CultureInfo("pt-BR"))</td>
                @* Formato brasileiro: DD/MM/AAAA [cite: 13, 16] *@
                <td>@item.DataLimite.ToString("dd/MM/yyyy")</td>
                <td>
                    <button type="button" onclick="openEditModal(@item.Id)" class="btn btn-primary btn-sm">Editar</button>

                    @* Confirmação de exclusão Sim/Não [cite: 28] *@
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Deseja realmente excluir esta tarefa?');">
                        <button type="submit" class="btn btn-danger btn-sm">Excluir</button>
                    </form>

                    @* Botões para reordenação [cite: 51] *@
                    <a asp-action="Subir" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">↑</a>
                    <a asp-action="Descer" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">↓</a>
                </td>
            </tr>
        }
    </tbody>
    <tfoot>
        <tr>
            <td><strong>Total:</strong></td>
            @* Somatório dos custos no rodapé [cite: 25] *@
            <td colspan="3"><strong>@Model.Sum(t => t.Custo).ToString("C2", new System.Globalization.CultureInfo("pt-BR"))</strong></td>
        </tr>
    </tfoot>
</table>

@* Botão para Incluir ao final [cite: 24] *@
<a asp-action="Create" class="btn btn-success">Incluir Nova Tarefa</a>

<div class="modal fade" id="editModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" id="modalContent">
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEditModal(id) {
            $.get("/Tarefas/Edit/" + id, function (data) {
                $("#modalContent").html(data);
                $("#editModal").modal("show");
            });
        }
    </script>
}