@model SistemaListaTarefas.Models.Tarefa

@{
    ViewData["Title"] = "Incluir Nova Tarefa";
}

<h2>@ViewData["Title"]</h2>

<form asp-action="Create">
    <div class="form-group">
        <label asp-for="Nome" class="control-label"></label>
        <input asp-for="Nome" class="form-control" autofocus />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Custo" class="control-label"></label>
        <input asp-for="Custo" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Custo" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DataLimite" class="control-label"></label>
        <input asp-for="DataLimite" class="form-control" type="date" />
        <span asp-validation-for="DataLimite" class="text-danger"></span>
    </div>
    <br />
    <button type="submit" class="btn btn-success">Salvar</button>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</form>