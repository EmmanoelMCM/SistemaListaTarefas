@model SistemaListaTarefas.Models.Tarefa

@{
    ViewData["Title"] = "Editar Tarefa";
}

<h2>@ViewData["Title"]</h2>

<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* O ID e a Ordem ficam ocultos para não serem alterados pelo usuário *@
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="Ordem" />

            <div class="form-group">
                <label asp-for="Nome" class="control-label"></label>
                <input asp-for="Nome" class="form-control" />
                <span asp-validation-for="Nome" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Custo" class="control-label"></label>
                @* Campo numérico com suporte a decimais *@
                <input asp-for="Custo" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Custo" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="DataLimite" class="control-label"></label>
                <input asp-for="DataLimite" class="form-control" type="date" />
                <span asp-validation-for="DataLimite" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <button type="submit" class="btn btn-primary">Salvar Alterações</button>
                <a asp-action="Index" class="btn btn-secondary">Voltar para a Lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}