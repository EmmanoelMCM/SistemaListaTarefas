@model SistemaListaTarefas.Models.Tarefa

<div class="modal-header">
    <h5 class="modal-title">Editar Tarefa</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>
<form asp-action="Edit" method="post">
    <div class="modal-body">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Ordem" />

        <div class="form-group mb-3">
            <label asp-for="Nome" class="control-label"></label>
            <input asp-for="Nome" class="form-control" />
            <span asp-validation-for="Nome" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Custo" class="control-label"></label>
            <input asp-for="Custo" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="Custo" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="DataLimite" class="control-label"></label>
            <input asp-for="DataLimite" class="form-control" type="date" asp-format="{0:yyyy-MM-dd}" />
            <span asp-validation-for="DataLimite" class="text-danger"></span>
        </div>
    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="submit" class="btn btn-primary">Salvar Alterações</button>
    </div>
</form>